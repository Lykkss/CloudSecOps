# ============================================================
# TEMPLATE D'ENVIRONNEMENT — CloudSecOps
# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env
# ============================================================

# --- AWS / LocalStack ---
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=eu-west-3
AWS_ENDPOINT_URL=http://localhost:4566

# --- Terraform ---
TF_VAR_aws_region=eu-west-3
TF_VAR_project_name=cloud-secops
TF_VAR_environment=dev
TF_VAR_localstack_enabled=true

# --- LocalStack ---
LOCALSTACK_AUTH_TOKEN=
LOCALSTACK_HOST=localhost
LOCALSTACK_PORT=4566

# --- Backend FastAPI (Sprint 3) ---
APP_ENV=development
APP_PORT=8000
SECRET_KEY=<generate: openssl rand -hex 32>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Base de données PostgreSQL (Sprint 3) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cloudsecops
POSTGRES_USER=cloudsecops
POSTGRES_PASSWORD=<define a strong password>
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/cloudsecops
